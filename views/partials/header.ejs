<!DOCTYPE html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | GameGrid</title>
    <meta
      name="description"
      content="GameGrid este un magazin online B2C de jocuri, cu catalog, cos, comenzi, facturi, administrare si plata electronica."
    />
    <link rel="stylesheet" href="/css/styles.css" />
    <script defer src="/js/app.js"></script>
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <div class="brand-row">
          <a class="brand-mark" href="/">
            <span class="brand-mark__symbol">GG</span>
            <span>
              <strong>GameGrid</strong>
              <small>store de jocuri PC</small>
            </span>
          </a>
          <button class="menu-toggle" type="button" data-menu-toggle aria-label="Deschide meniul">
            Menu
          </button>
        </div>
        <nav class="site-nav" data-menu>
          <a href="/" class="<%= currentPath === '/' ? 'is-active' : '' %>">Acasa</a>
          <a href="/catalog" class="<%= currentPath.startsWith('/catalog') ? 'is-active' : '' %>">Catalog</a>
          <a href="/ritual-personalizat" class="<%= currentPath.startsWith('/ritual-personalizat') ? 'is-active' : '' %>">Loadout Builder</a>
          <a href="/cart" class="<%= currentPath.startsWith('/cart') ? 'is-active' : '' %>">Cos (<%= cartCount %>)</a>
          <% if (currentUser) { %>
            <a href="/account" class="<%= currentPath.startsWith('/account') ? 'is-active' : '' %>">Cont</a>
            <% if (currentUser.role === 'admin') { %>
              <a href="/admin" class="<%= currentPath.startsWith('/admin') ? 'is-active' : '' %>">Admin</a>
            <% } %>
            <form action="/logout" method="post">
              <button type="submit" class="ghost-button">Logout</button>
            </form>
          <% } else { %>
            <a href="/login" class="<%= currentPath.startsWith('/login') ? 'is-active' : '' %>">Login</a>
            <a href="/register" class="<%= currentPath.startsWith('/register') ? 'is-active' : '' %>">Inregistrare</a>
          <% } %>
        </nav>
      </header>

      <% if (flash) { %>
        <div class="flash flash--<%= flash.type %>" data-flash>
          <%= flash.message %>
        </div>
      <% } %>

      <main class="content-shell">

