<%- include('../partials/header', { title }) %>

<section class="section-head">
  <div>
    <p class="eyebrow">Admin utilizatori</p>
    <h1>Gestiune utilizatori</h1>
  </div>
</section>

<section class="card">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Nume</th>
          <th>Email</th>
          <th>Rol</th>
          <th>Comenzi</th>
          <th>Creat</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach((user) => { %>
          <tr>
            <td><%= user.name %></td>
            <td><%= user.email %></td>
            <td><%= user.role %></td>
            <td><%= user.order_count %></td>
            <td><%= new Date(user.created_at).toLocaleDateString('ro-RO') %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('../partials/footer') %>
