<%- include('../partials/header', { title }) %>

<section class="section-head">
  <div>
    <p class="eyebrow">Admin catalog</p>
    <h1>Gestiune produse</h1>
  </div>
</section>

<section class="two-column two-column--admin">
  <div class="card">
    <h2>Adauga produs</h2>
    <form action="/admin/products" method="post" class="stack-form">
      <label>
        Categorie
        <select name="categoryId" required>
          <% categories.forEach((category) => { %>
            <option value="<%= category.id %>"><%= category.name %></option>
          <% }) %>
        </select>
      </label>
      <label>
        Nume produs
        <input type="text" name="name" required />
      </label>
      <label>
        Tagline
        <input type="text" name="tagline" required />
      </label>
      <label>
        Descriere
        <textarea name="description" rows="4" required></textarea>
      </label>
      <label>
        URL imagine produs
        <input type="url" name="image" placeholder="https://..." />
      </label>
      <div class="form-row">
        <label>
          Pret (lei)
          <input type="number" name="price" step="0.01" required />
        </label>
        <label>
          Promo %
          <input type="number" name="promoPercent" min="0" max="80" />
        </label>
      </div>
      <div class="form-row">
        <label>
          Stoc
          <input type="number" name="stock" min="0" required />
        </label>
        <label>
          Accent
          <input type="color" name="accent" value="#6B705C" />
        </label>
      </div>
      <div class="form-row">
        <label>
          Textura
          <input type="text" name="texture" value="studio" />
        </label>
        <label>
          Tag gameplay
          <input type="text" name="concern" value="general" />
        </label>
      </div>
      <label class="checkbox">
        <input type="checkbox" name="featured" />
        marcheaza ca featured
      </label>
      <button type="submit" class="button">Salveaza produs</button>
    </form>
  </div>

  <div class="card">
    <h2>Actualizare rapida</h2>
    <div class="stack-list">
      <% products.forEach((product) => { %>
        <form action="/admin/products/<%= product.id %>" method="post" class="product-admin-row">
          <div>
            <strong><%= product.name %></strong>
            <p><%= product.category_name %></p>
          </div>
          <label>
            Pret
            <input type="number" step="0.01" name="price" value="<%= (product.price_cents / 100).toFixed(2) %>" />
          </label>
          <label>
            Promo
            <input type="number" name="promoPercent" min="0" max="80" value="<%= product.promo_percent %>" />
          </label>
          <label>
            Stoc
            <input type="number" name="stock" min="0" value="<%= product.stock %>" />
          </label>
          <label class="checkbox">
            <input type="checkbox" name="featured" <%= product.featured ? 'checked' : '' %> />
            featured
          </label>
          <button type="submit" class="ghost-button">Update</button>
        </form>
      <% }) %>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>

